# ============================================================================
# Sherin
# Own key. Own domain. Own storage.
#
# First deploy tip:
# - Keep the default stack until your first build works.
# - Fill required values only.
# - Leave optional fields blank until you intentionally choose to use them.
# - Never commit real secret values to Git.
# ============================================================================

# Stack (default)
# - Database & auth: supabase
# - Storage: supabase-storage
# - Inference: runway
# - Hosting: vercel
#
# Stack (custom)
# - Database & auth: supabase
# - Storage: aws-s3/backblaze-b2/cloudflare-r2/supabase-storage/vercel-blob
# - Inference: runway/babysea
# - Hosting: digitalocean/netlify/railway/render/vercel

# ----------------------------------------------------------------------------
# CONFIG
# ----------------------------------------------------------------------------

# The exact URL where the app runs
# Local development: http://localhost:3011
# Production (your custom domain): https://your-domain.example.com
NEXT_PUBLIC_SITE_URL=

# Single-user access (only this email can enter the dashboard)
OWNER_EMAIL=

# ----------------------------------------------------------------------------
# DATABASE & AUTH
# ----------------------------------------------------------------------------

# Database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=
SUPABASE_SECRET_KEY=

# Auth
# In your Google Cloud console:
# - Create OAuth 2.0 Client IDs for `Web application`
# - Add `https://your-domain.example.com` in `Authorized JavaScript origins`
# - Add `https://your-supabase-project-id.supabase.co/auth/v1/callback` in `Authorized redirect URIs`
# - Copy `Client ID` and `Client secrets`
# In your Supabase dashboard:
# - Enable Sign in with Google
# - Fill `Client IDs` and `Client Secret (for OAuth)` from your Google Cloud console above
# - Add `https://your-domain.example.com` in `Site URL`
# - Add `https://your-domain.example.com/auth/callback` in `Redirect URLs`

# ----------------------------------------------------------------------------
# INFERENCE
# ----------------------------------------------------------------------------

# Default: runway
# Allowed: runway, babysea
INFERENCE_PROVIDER=runway

# If INFERENCE_PROVIDER=runway, fill the value below
# Learn: https://docs.dev.runwayml.com
RUNWAYML_API_SECRET=

# If INFERENCE_PROVIDER=babysea, fill the value below
# Learn: https://docs.babysea.ai
# You should change BABYSEA_API_BASE_URL depend on your account region
BABYSEA_API_KEY=
BABYSEA_API_BASE_URL=https://api.us.babysea.ai

# ----------------------------------------------------------------------------
# STORAGE
# ----------------------------------------------------------------------------

# Default: supabase-storage
# Allowed: aws-s3, backblaze-b2, cloudflare-r2, supabase-storage, vercel-blob
STORAGE_PROVIDER=supabase-storage

# Default: 10
# Per-owner stored image limit in GB (use a whole number like 10, 50, 100, etc)
CUSTOM_USER_STORAGE_QUOTA_GB=10

# Fill these only if STORAGE_PROVIDER=aws-s3
# - AWS_S3_BUCKET_NAME is the bucket app writes objects into
# - AWS_S3_ENDPOINT_URL is the browser-readable image base URL, preferably CloudFront or a custom domain
#   Example: https://your-cloudfront-domain or https://your-media-domain
AWS_S3_REGION=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# Fill these only if STORAGE_PROVIDER=backblaze-b2
# - BACKBLAZE_B2_BUCKET_NAME is the private/public bucket app writes objects into
# - No public bucket URL or S3 endpoint is required; app uses the native B2 API and signed download URLs
# - Standard Backblaze aliases also work: B2_KEY_ID, B2_APP_KEY, B2_BUCKET_NAME, and optional B2_BUCKET_ID
BACKBLAZE_B2_KEY_ID=
BACKBLAZE_B2_APPLICATION_KEY=
BACKBLAZE_B2_BUCKET_NAME=
# BACKBLAZE_B2_BUCKET_ID=

# Fill these only if STORAGE_PROVIDER=cloudflare-r2
# - CLOUDFLARE_R2_ENDPOINT_URL is your `S3 API` url, example: https://your-r2-account-id.r2-region.r2.cloudflarestorage.com/r2-bucket-name
# - CLOUDFLARE_R2_CUSTOM_DOMAIN_URL is your public read url, example: https://pub-token.r2.dev or https://your-storage.example.com
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_CUSTOM_DOMAIN_URL=

# Fill this only if STORAGE_PROVIDER=vercel-blob
# Vercel hosting is the simplest path if you use this as your STORAGE_PROVIDER
BLOB_READ_WRITE_TOKEN=

# ----------------------------------------------------------------------------
# WORKER (optional)
# ----------------------------------------------------------------------------

# Skip this for your first deploy unless you configure an external cron
# Shared secret used by external cron pollers calling:
# `/api/generations/process` with `Authorization: Bearer <token>`
# Generate strong secret with: openssl rand -hex 32
CRON_SECRET=

# ----------------------------------------------------------------------------
# OBSERVABILITY (optional)
# ----------------------------------------------------------------------------

# Sentry
# Skip this for your first deploy unless you already use Sentry
# Learn: https://docs.sentry.io/platforms/javascript/guides/nextjs
# Sample rates (traces/replays) are hardcoded in (edit to tune):
# - `lib/monitoring/sentry-config.ts`
# - `instrumentation-client.ts`
# Leave blank to run without error tracking (the app no-ops cleanly)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# Required only to upload source maps at build time (never expose to client)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
